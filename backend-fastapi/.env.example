# App
DEBUG=False
SECRET_KEY=your-super-secret-key-change-this

# Database (PostgreSQL)
DATABASE_URL=postgresql://user:password@localhost:5432/custherds

# Token
ACCESS_TOKEN_EXPIRE_MINUTES=1440
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS
ALLOWED_ORIGINS=["http://localhost:3000","https://partners-custherds.ourtestcloud.my.id"]

# Swagger Basic Auth
SWAGGER_USERNAME=admin
